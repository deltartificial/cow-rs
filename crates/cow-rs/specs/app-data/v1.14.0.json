        "replacedOrder": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "required": [
            "uid"
          ],
          "title": "Replaced order",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "uid": {
              "pattern": "^0x[a-fA-F0-9]{112}$",
              "title": "Replaced order UID",
              "examples": [
                "0xff2e2e54d178997f173266817c1e9ed6fee1a1aae4b43971c53b543cffcc2969845c6f5599fbb25dbdd1b9b013daf85c03f3c63763e4bc4a"
              ],
              "type": "string",
              "description": "The replaced order UID."
            }
          }
        },
        "bridging": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "required": [
            "providerId",
            "destinationChainId",
            "destinationTokenAddress"
          ],
          "title": "Bridging",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "providerId": {
              "title": "Id of bridging provider",
              "examples": [
                "75716a3cb48fdbb43ebdff58ce6c541f6a2c269be690513131355800367f2da2"
              ],
              "type": "string",
              "minLength": 1,
              "description": "The id links order with a bridging provider which processes it"
            },
            "destinationChainId": {
              "pattern": "^[a-zA-Z0-9\\-_]{1,32}$",
              "title": "Bridging destination chainId",
              "examples": [
                "1",
                "100",
                "hedera-hashgraph"
              ],
              "type": "string",
              "description": "Id of a blockchain where funds will be received"
            },
            "destinationTokenAddress": {
              "title": "Bridging destination token address",
              "description": "Address of a token that will be received at destination chain. The chain might be EVM or non-EVM. Some chains might even not have a token address. E.g.: Bitcoin",
              "type": "string",
              "pattern": "^[a-zA-Z0-9\\-.]{1,64}$",
              "examples": [
                "0x00E989b87700514118Fa55326CD1cCE82faebEF6",
                "A.b19436aae4d94622.FiatToken",
                "0.0.456858",
                "1337"
              ]
            },
            "quoteId": {
              "title": "Bridge provider quote id",
              "description": "An ID of a quote which is used for bridging",
              "type": "string",
              "examples": [
                "60012"
              ]
            },
            "quoteSignature": {
              "title": "Bridge provider quote signature",
              "description": "Provider who implement ReceiverAccountBridgeProvider must return a signature of a quote than will be used to verify the quote deposit address validity",
              "type": "string",
              "examples": [
                "ed25519:Y54QM45ockDtJf3uAVhV8xndF79GPeQW5fJaZZLKfnaj8mW9NaBDsGg3uVXY1Fge73fYDAsdn9qokhjm2rsJATz"
              ]
            },
            "attestationSignature": {
              "title": "Bridge provider attestation signature",
              "description": "For ReceiverAccountBridgeProvider, this is the attestation signature from the bridge provider that validates the deposit address. Empty for other provider types.",
              "type": "string",
              "examples": [
                "0x1234567890abcdef..."
              ]
            },
            "quoteBody": {
              "title": "Bridge provider quote body",
              "description": "A stringified JSON of quote which is associated with the order.",
              "type": "string",
              "examples": [
                "{\"dry\":false,\"swapType\":\"EXACT_INPUT\",\"slippageTolerance\":100,...}"
              ]
            }
          }
        },
        "flashloan": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "title": "Flashloan",
          "description": "Information about flashloan parameters for the order",
          "type": "object",
          "required": [
            "amount",
            "liquidityProvider",
            "protocolAdapter",
            "receiver",
            "token"
          ],
          "properties": {
            "amount": {
              "pattern": "^[1-9]\\d*$",
              "title": "Loan amount",
              "examples": [
                "90741097240912730913",
                "75891372",
                "1"
              ],
              "type": "string",
              "description": "The amount of tokens to be flash loaned (in token units, as uint256)"
            },
            "liquidityProvider": {
              "pattern": "^0x[a-fA-F0-9]{40}$",
              "title": "Liquidity provider address",
              "examples": [
                "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
              ],
              "type": "string",
              "description": "The Ethereum address of the flashloan liquidity provider"
            },
            "protocolAdapter": {
              "pattern": "^0x[a-fA-F0-9]{40}$",
              "title": "Protocol adapter address",
              "examples": [
                "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
              ],
              "type": "string",
              "description": "The Ethereum address of the protocol adapter"
            },
            "receiver": {
              "pattern": "^0x[a-fA-F0-9]{40}$",
              "title": "Receiver address",
              "examples": [
                "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
              ],
              "type": "string",
              "description": "The Ethereum address of the flashloan receiver"
            },
            "token": {
              "pattern": "^0x[a-fA-F0-9]{40}$",
              "title": "Token address",
              "examples": [
                "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
              ],
              "type": "string",
              "description": "The Ethereum address of the token being borrowed"
            }
          },
          "additionalProperties": false
        },
        "wrappers": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "title": "Wrappers",
          "description": "Information about wrappers to execute for the order",
          "type": "array",
          "items": {
            "title": "Wrapper Entry",
            "description": "Information about an individual wrapper to execute for the order",
            "type": "object",
            "required": [
              "address"
            ],
            "properties": {
              "address": {
                "pattern": "^0x[a-fA-F0-9]{40}$",
                "title": "Wrapper address",
                "examples": [
                  "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
                ],
                "type": "string",
                "description": "The Ethereum address of the wrapper to execute"
              },
              "data": {
                "pattern": "^0x[a-f0-9]*$",
                "title": "Wrapper data",
                "examples": [
                  "0x",
                  "0x1",
                  "0xfac282674bbdb"
                ],
                "type": "string",
                "description": "Any additional data. The format of this data will vary depending on the wrapper you are calling. If left unspecified, this field defaults to 0x (empty wrapper data)"
              },
              "isOmittable": {
                "title": "Is Omittable",
                "description": "Whether or not this wrapper must be executed exactly as given with the order. If left unspecified, this field defaults to `false` (wrapper data must be executed with the order exactly as given)",
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "userConsents": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "title": "User Consents",
          "description": "Array of user consents for terms acceptance",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "terms",
              "acceptedDate"
            ],
            "additionalProperties": false,
            "properties": {
              "terms": {
                "type": "string",
                "description": "IPFS hash of the accepted terms",
                "examples": [
                  "QmYwAPJzv5CZsnAzt8auVZRn5DfvPYg8X7yGvkb5sNqBmV"
                ]
              },
              "acceptedDate": {
                "type": "string",
                "description": "ISO 8601 date-time when user accepted the terms in the UI",
                "examples": [
                  "2025-11-11T23:00:00Z"
                ]
              }
            }
          }
        }
      }
    }
  }
}
