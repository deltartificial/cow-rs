{
  "$schema": "http://json-schema.org/draft-07/schema",
  "description": "Metadata JSON document for adding information to orders.",
  "required": [
    "version",
    "metadata"
  ],
  "title": "AppData Root Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "Semantic versioning of document.",
      "readOnly": true,
      "examples": [
        "1.0.0",
        "1.2.3"
      ],
      "title": "Version",
      "type": "string",
      "default": "1.0.0"
    },
    "appCode": {
      "description": "The code identifying the CLI, UI, service generating the order.",
      "examples": [
        "CoW Swap"
      ],
      "title": "App Code",
      "type": "string"
    },
    "environment": {
      "description": "Environment from which the order came from.",
      "title": "Environment",
      "type": "string",
      "examples": [
        "production",
        "development",
        "staging",
        "ens"
      ]
    },
    "metadata": {
      "default": {},
      "description": "Each metadata will specify one aspect of the order.",
      "required": [],
      "title": "Metadata",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signer": {
          "pattern": "^0x[a-fA-F0-9]{40}$",
          "title": "Signer",
          "examples": [
            "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
          ],
          "type": "string",
          "$schema": "http://json-schema.org/draft-07/schema",
          "description": "The address of the trader who signs the CoW Swap order. This field should normally be omitted; it is recommended to use it if the signer is a smart-contract wallet using EIP-1271 signatures."
        },
        "referrer": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "required": [
            "address"
          ],
          "title": "Referrer",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "address": {
              "pattern": "^0x[a-fA-F0-9]{40}$",
              "title": "Referrer address",
              "examples": [
                "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
              ],
              "type": "string"
            }
          }
        },
        "utm": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "required": [],
          "title": "UTM Codes",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "utmSource": {
              "title": "UTM Source",
              "type": "string",
              "examples": [
                "twitter"
              ],
              "description": "Tracks in which medium the traffic originated from (twitter, facebook, etc.)"
            },
            "utmMedium": {
              "title": "UTM Medium",
              "type": "string",
              "examples": [
                "email"
              ],
              "description": "Tracks in which medium the traffic originated from (mail, CPC, social, etc.)"
            },
            "utmCampaign": {
              "title": "UTM Campaign",
              "type": "string",
              "examples": [
                "everyone-loves-cows-2023"
              ],
              "description": "Track the performance of a specific campaign"
            },
            "utmContent": {
              "title": "UTM Content",
              "type": "string",
              "examples": [
                "big-fat-button"
              ],
              "description": "Track which link was clicked"
            },
            "utmTerm": {
              "title": "UTM Keyword Term",
              "type": "string",
              "examples": [
                "coincidence+of+wants"
              ],
              "description": "Track which keyword term a website visitor came from"
            }
          }
        },
        "quote": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "required": [
            "slippageBips"
          ],
          "title": "Quote",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "slippageBips": {
              "title": "Slippage Bips",
              "description": "Slippage tolerance that was applied to the order to get the limit price. Expressed in Basis Points (BPS). One basis point is equivalent to 0.01% (1/100th of a percent)",
              "examples": [
                0,
                10,
                50
              ],
              "type": "integer",
              "maximum": 10000,
              "minimum": 0
            }
          }
        },
        "orderClass": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "required": [
            "orderClass"
          ],
          "title": "Order class",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "orderClass": {
              "description": "Indicator of the order class.",
              "examples": [
                "market",
                "limit",
                "liquidity",
                "twap"
              ],
              "title": "Order class",
              "type": "string",
              "enum": [
                "market",
                "limit",
                "liquidity",
                "twap"
              ]
            }
          }
        },
        "hooks": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "default": {},
          "required": [],
          "title": "Order interaction hooks",
          "description": "Optional Pre and Post order interaction hooks attached to a single order",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "version": {
              "description": "Semantic versioning of document.",
              "readOnly": true,
              "examples": [
                "1.0.0",
                "1.2.3"
              ],
              "title": "Version",
              "type": "string",
              "default": "0.1.0"
            },
            "pre": {
              "title": "Pre-Hooks",
              "description": "CoW Hooks to call before an order executes",
              "type": "array",
              "items": {
                "$schema": "http://json-schema.org/draft-07/schema",
                "required": [
                  "target",
                  "callData",
                  "gasLimit"
                ],
                "title": "CoW Hook",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "target": {
                    "pattern": "^0x[a-fA-F0-9]{40}$",
                    "title": "Hook Target",
                    "examples": [
                      "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
                    ],
                    "type": "string",
                    "description": "The contract to call for the hook"
                  },
                  "callData": {
                    "title": "Hook CallData",
                    "description": "The calldata to use when calling the hook",
                    "type": "string",
                    "pattern": "^0x[a-fA-F0-9]*$",
                    "examples": [
                      "0x",
                      "0x01020304"
                    ]
                  },
                  "gasLimit": {
                    "pattern": "^\\d+$",
                    "title": "Hook Gas Limit",
                    "examples": [
                      "90741097240912730913",
                      "0",
                      "75891372"
                    ],
                    "type": "string",
                    "description": "The gas limit (in gas units) for the hook"
                  }
                }
              }
            },
            "post": {
              "title": "Post-Hooks",
              "description": "CoW Hooks to call after an order executes",
              "type": "array",
              "items": {
                "$schema": "http://json-schema.org/draft-07/schema",
                "required": [
                  "target",
                  "callData",
                  "gasLimit"
                ],
                "title": "CoW Hook",
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "target": {
                    "pattern": "^0x[a-fA-F0-9]{40}$",
                    "title": "Hook Target",
                    "examples": [
                      "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
                    ],
                    "type": "string",
                    "description": "The contract to call for the hook"
                  },
                  "callData": {
                    "title": "Hook CallData",
                    "description": "The calldata to use when calling the hook",
                    "type": "string",
                    "pattern": "^0x[a-fA-F0-9]*$",
                    "examples": [
                      "0x",
                      "0x01020304"
                    ]
                  },
                  "gasLimit": {
                    "pattern": "^\\d+$",
                    "title": "Hook Gas Limit",
                    "examples": [
                      "90741097240912730913",
                      "0",
                      "75891372"
                    ],
                    "type": "string",
                    "description": "The gas limit (in gas units) for the hook"
                  }
                }
              }
            }
          }
        },
        "widget": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "required": [
            "appCode"
          ],
          "title": "Widget",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "appCode": {
              "description": "The code identifying the UI powering the widget",
              "examples": [
                "CoW Swap"
              ],
              "title": "App Code",
              "type": "string"
            },
            "environment": {
              "description": "Environment from which the order came from.",
              "title": "Environment",
              "type": "string",
              "examples": [
                "production",
                "development",
                "staging",
                "ens"
              ]
            }
          }
        },
        "partnerFee": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "required": [
            "bps",
            "recipient"
          ],
          "title": "Partner fee",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bps": {
              "title": "Basis Point (BPS)",
              "description": "The fee in basis points (BPS) to be paid to the partner. One basis point is equivalent to 0.01% (1/100th of a percent)",
              "examples": [
                0,
                10,
                50
              ],
              "type": "integer",
              "maximum": 10000,
              "minimum": 0
            },
            "recipient": {
              "pattern": "^0x[a-fA-F0-9]{40}$",
              "title": "Partner account",
              "examples": [
                "0xb6BAd41ae76A11D10f7b0E664C5007b908bC77C9"
              ],
              "type": "string",
              "description": "The Ethereum address of the partner to receive the fee."
            }
          }
        }
      }
    }
  }
}
