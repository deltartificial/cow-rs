                    },
                    "maxVolumeBps": {
                      "title": "Max Volume Basis Point (BPS)",
                      "description": "The maximum volume in basis points (BPS) to be paid to the partner. Capped at protocol level to 100 BPS (1%). You can chose to go lower but not higher",
                      "type": "integer",
                      "maximum": 100,
                      "minimum": 1,
                      "default": 100,
                      "examples": [
